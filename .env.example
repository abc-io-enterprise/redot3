# ABC-IO v2.0 production environment template
# Copy this file to .env and replace values with secure production secrets.
# Do not commit .env to source control.

# === AI Provider ===
AI_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
KIMI_API_KEY=
KIMI_MODEL=kimi-k2-0711-preview
KIMI_API_BASE_URL=https://api.kimi.ai/v1

# === Database ===
POSTGRES_DB=abcio
POSTGRES_USER=abcio
POSTGRES_PASSWORD=changeme

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# === Owner Dashboard ===
OWNER_ACCOUNT_EMAIL=owner@abc-io.com
OWNER_ACCOUNT_PASSWORD=secure-owner-password
OWNER_SESSION_TOKEN=owner-session-token
OWNER_SIGNING_KEY=owner-private-key
OWNER_SIGNING_FINGERPRINT=owner-fingerprint-123

# === Mobile Gateway ===
MOBILE_SIGNING_KEY=mobile-private-key
MOBILE_SIGNING_FINGERPRINT=mobile-fingerprint-456

# === Public Portal ===
PUBLIC_SIGNING_KEY=public-private-key
PUBLIC_SIGNING_FINGERPRINT=public-fingerprint-789

# === Gateway ===
GATEWAY_API_KEY=gateway-api-key
JWT_SECRET=generate-32-byte-hex-secret
PUBLIC_URL=https://abc-io.com
CORS_ORIGIN=https://abc-io.com

# === Billing (Stripe) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FREE=price_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_STANDARD=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_PRICE_ID_CORPORATE=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...
STRIPE_PRICE_ID_AGENCY=price_...
STRIPE_PRICE_ID_GLOBAL=price_...

# === Billing (PayPal) ===
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# === Email (SMTP) ===
SMTP_URL=smtps://user:pass@smtp.abc-io.com:465
SMTP_HOST=smtp.abc-io.com
SMTP_PORT=465
SMTP_USER=noreply@abc-io.com
SMTP_PASS=generate-smtp-password
SMTP_FROM=ABC-IO <noreply@abc-io.com>

# === Self-Heal ===
SELF_HEAL_TOKEN=local-self-heal-token

# === Observability ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# === Headscale VPN ===
HEADSCALE_SERVER_URL=https://headscale.abc-io.com:8085
HEADSCALE_BASE_DOMAIN=abc-io.com
HEADSCALE_MAGIC_DNS=true
HEADSCALE_API_KEY=

# === Gitea (if used) ===
GITEA_DOMAIN=gitea.abc-io.com
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_EMAIL=admin@abc-io.com
GITEA_ADMIN_PASSWORD=changeme
GITEA_SECRET_KEY=
GITEA_INTERNAL_TOKEN=
GITEA_DB_PASSWORD=
GITEA_SSH_HOST_KEY_PATH=

# === Namecheap DNS ===
NAMECHEAP_VPS_API_KEY=
NAMECHEAP_VPS_PANEL=namecheap.com
NAMECHEAP_SHARED_HOSTING_API_KEY=
NAMECHEAP_SHARED_HOSTING_DOMAIN=abc-io.com

# === VPS Deployment ===
REDOT1_IP=162.254.32.142
AI1_IP=159.203.110.44
AI2_IP=159.203.44.3

OWNER_BIOMETRIC_SECRET=generate-32-byte-hex-secret
REDOT1_API_KEY=generate-24-byte-hex-key
