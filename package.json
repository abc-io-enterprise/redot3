{
  "name": "abc-io-v2",
  "version": "v5.0.0",
  "description": "ABC-IO — Universal silicone and carbon cross-sensory information sharing communications platform",
  "private": true,
  "workspaces": [
    "services/gateway",
    "services/operator-station",
    "services/owner-dashboard",
    "services/mobile-gateway",
    "services/public-portal",
    "services/beacon-pwa",
    "services/account-pwa",
    "services/interface-pwa"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml up -d",
    "dev:logs": "docker compose -f docker-compose.yml up",
    "prod": "docker compose -f compose.prod.yml up -d",
    "prod:logs": "docker compose -f compose.prod.yml up",
    "staging": "docker compose -f compose.staging.yml up -d",
    "staging:logs": "docker compose -f compose.staging.yml up",
    "replica:ai1": "docker compose -f compose.replica-ai1.yml up -d",
    "replica:ai2": "docker compose -f compose.replica-ai2.yml up -d",
    "build": "docker compose build",
    "stop": "docker compose down",
    "health": "bash scripts/health-check.sh",
    "verify": "bash scripts/verify-cloud-deployment.sh",
    "heal": "bash scripts/auto-heal.sh",
    "test": "echo 'Run individual service tests'",
    "apk:build": "bash apk/build-apk-manual.sh",
    "apk:autonomous": "bash scripts/build-autonomous-apk.sh",
    "orchestrator": "python scripts/autonomous-orchestrator.py",
    "orchestrator:daemon": "python scripts/autonomous-orchestrator.py --daemon",
    "desktop:admin": "python admin-desktop/server.py",
    "deploy:vps": "bash scripts/deploy-vps-cluster.sh",
    "lint": "echo 'Linting not configured'",
    "format": "echo 'Formatting not configured'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abc-io-enterprise/redot2.git"
  },
  "license": "PROPRIETARY"
}
