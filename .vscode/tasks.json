{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker compose -f compose.dev.yml up --build -d",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Down",
      "type": "shell",
      "command": "docker compose -f compose.dev.yml down --remove-orphans",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build APK",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "scripts/build-mobile-apk.ps1"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": [],
      "windows": {
        "command": "powershell",
        "args": ["-File", "scripts/build-mobile-apk.ps1"]
      }
    },
    {
      "label": "Run Health Checks",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/health-check.sh"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy to GCP",
      "type": "shell",
      "command": "terraform -chdir=infrastructure/gcp/terraform init && terraform -chdir=infrastructure/gcp/terraform apply -auto-approve",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "npm test --workspaces --if-present",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"]
    }
  ]
}
